{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-bom.dev/contracts/v1/scan-report.schema.json",
  "title": "agent-bom scan report v1",
  "type": "object",
  "required": ["schema_version", "document_type", "spec_version", "scan_id", "generated_at", "scan_run", "summary", "agents"],
  "properties": {
    "schema_version": { "type": "string", "pattern": "^1(\\.\\d+)?$" },
    "document_type": { "const": "AI-BOM" },
    "spec_version": { "type": "string", "pattern": "^1(\\.\\d+)?$" },
    "scan_id": { "type": "string", "minLength": 1 },
    "ai_bom_version": { "type": "string" },
    "generated_at": { "type": "string", "format": "date-time" },
    "scan_sources": { "type": "array", "items": { "type": "string" } },
    "warnings": {
      "type": "array",
      "maxItems": 100,
      "items": { "type": "string", "maxLength": 1000 }
    },
    "coverage_warnings": {
      "type": "array",
      "description": "OS releases whose vulnerability data the source does not carry (typically end-of-life); a low/zero count for these must not be read as clean.",
      "items": {
        "type": "object",
        "required": ["ecosystem", "release", "reason", "detail"],
        "properties": {
          "ecosystem": { "type": "string" },
          "release": { "type": "string" },
          "reason": { "type": "string" },
          "detail": { "type": "string" },
          "package_count": { "type": "integer", "minimum": 0 },
          "advisory_rows": { "type": "integer", "minimum": 0 }
        },
        "additionalProperties": true
      }
    },
    "summary": {
      "type": "object",
      "required": ["total_agents", "total_mcp_servers", "total_packages", "total_vulnerabilities"],
      "properties": {
        "total_agents": { "type": "integer", "minimum": 0 },
        "total_mcp_servers": { "type": "integer", "minimum": 0 },
        "total_packages": { "type": "integer", "minimum": 0 },
        "total_vulnerabilities": { "type": "integer", "minimum": 0 },
        "critical_findings": { "type": "integer", "minimum": 0 },
        "coverage_warnings": { "type": "array", "items": { "type": "object" } }
      },
      "additionalProperties": true
    },
    "agents": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "stable_id", "status", "mcp_servers"],
        "anyOf": [
          { "required": ["agent_type"] },
          { "required": ["type"] }
        ],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "stable_id": { "type": "string", "minLength": 1 },
          "agent_type": {
            "type": "string",
            "minLength": 1,
            "description": "Canonical agent type field used by the Python model and UI clients."
          },
          "type": {
            "type": "string",
            "minLength": 1,
            "description": "Backward-compatible alias for agent_type retained for v1 scan-report consumers."
          },
          "status": { "type": "string", "minLength": 1 },
          "discovered_at": { "type": "string", "format": "date-time" },
          "last_seen": { "type": "string", "format": "date-time" },
          "mcp_servers": { "type": "array" }
        },
        "additionalProperties": true
      }
    },
    "scan_run": {
      "type": "object",
      "required": ["schema_version", "scan_id", "generated_at", "outcome", "issues", "warning_count"],
      "properties": {
        "schema_version": { "type": "string", "pattern": "^1(\\.\\d+)?$" },
        "scan_id": { "type": "string" },
        "generated_at": { "type": "string", "format": "date-time" },
        "outcome": { "enum": ["complete", "partial", "failed"] },
        "warning_count": { "type": "integer", "minimum": 0 },
        "issues": {
          "type": "array",
          "maxItems": 100,
          "items": {
            "type": "object",
            "required": ["code", "stage", "source", "message", "severity", "affects_coverage"],
            "properties": {
              "code": { "type": "string", "minLength": 1, "maxLength": 100 },
              "stage": { "type": "string", "minLength": 1, "maxLength": 100 },
              "source": { "type": "string", "minLength": 1, "maxLength": 200 },
              "message": { "type": "string", "minLength": 1, "maxLength": 1000 },
              "severity": { "enum": ["warning", "error"] },
              "affects_coverage": { "type": "boolean" }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": true
    },
    "blast_radius": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["schema_version"],
        "properties": {
          "schema_version": { "type": "string", "pattern": "^1(\\.\\d+)?$" }
        },
        "additionalProperties": true
      }
    },
    "findings": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["schema_version"],
        "properties": {
          "schema_version": { "type": "string", "pattern": "^1(\\.\\d+)?$" }
        },
        "additionalProperties": true
      }
    },
    "inventory_snapshot": {
      "type": "object",
      "required": ["schema_version"],
      "properties": {
        "schema_version": { "type": "string", "pattern": "^1(\\.\\d+)?$" }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
