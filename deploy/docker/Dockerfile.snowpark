## ── Builder stage ────────────────────────────────────────────────────────────
FROM python:3.11-slim@sha256:c8271b1f627d0068857dce5b53e14a9558603b527e46f1f901722f935b786a39 AS builder

WORKDIR /app

COPY pyproject.toml README.md LICENSE ./
COPY src/ ./src/

RUN pip install --no-cache-dir --prefix=/install ".[api,snowflake]"

## ── Runtime stage ────────────────────────────────────────────────────────────
FROM python:3.11-slim@sha256:c8271b1f627d0068857dce5b53e14a9558603b527e46f1f901722f935b786a39

ARG VERSION=0.70.8

LABEL maintainer="W S <34316639+msaad00@users.noreply.github.com>"
LABEL description="agent-bom API for Snowpark Container Services"
LABEL org.opencontainers.image.source="https://github.com/msaad00/agent-bom"
LABEL org.opencontainers.image.version="${VERSION}"
LABEL org.opencontainers.image.licenses="Apache-2.0"

# Copy only installed packages from builder (no pip, setuptools)
COPY --from=builder /install /usr/local
COPY --from=builder /app/LICENSE /app/LICENSE

RUN addgroup --system abom && adduser --system --ingroup abom abom
USER abom

ENV PYTHONUNBUFFERED=1

EXPOSE 8422

HEALTHCHECK --interval=30s --timeout=10s --start-period=5s --retries=3 \
    CMD python -c "import urllib.request; urllib.request.urlopen('http://localhost:8422/health')" || exit 1

ENTRYPOINT ["agent-bom", "api", "--host", "0.0.0.0", "--port", "8422"]
