          "rawSql": "SELECT toDate(scan_timestamp) AS time, severity, count() AS cnt FROM agent_bom.vulnerability_scans WHERE scan_timestamp >= now() - INTERVAL 30 DAY GROUP BY time, severity ORDER BY time",
