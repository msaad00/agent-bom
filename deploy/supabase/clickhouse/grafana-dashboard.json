          "rawSql": "SELECT toStartOfHour(event_timestamp) AS time, event_type, count() AS cnt FROM agent_bom.runtime_events WHERE event_timestamp >= now() - INTERVAL 24 HOUR GROUP BY time, event_type ORDER BY time",
