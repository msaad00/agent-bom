      "type": "table",
      "targets": [
        {
          "rawSql": "SELECT cve_id, count() AS cnt, max(cvss_score) AS max_cvss FROM agent_bom.vulnerability_scans WHERE cve_id != '' GROUP BY cve_id ORDER BY cnt DESC LIMIT 20",
          "format": 1
