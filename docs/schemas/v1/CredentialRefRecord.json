{
  "$defs": {
    "CredentialRefStatus": {
      "enum": [
        "configured",
        "healthy",
        "degraded",
        "disabled",
        "retired"
      ],
      "title": "CredentialRefStatus",
      "type": "string"
    }
  },
  "properties": {
    "created_at": {
      "default": "",
      "title": "Created At",
      "type": "string"
    },
    "credential_class": {
      "default": "generic",
      "title": "Credential Class",
      "type": "string"
    },
    "credential_ref_id": {
      "title": "Credential Ref Id",
      "type": "string"
    },
    "description": {
      "default": "",
      "title": "Description",
      "type": "string"
    },
    "display_name": {
      "title": "Display Name",
      "type": "string"
    },
    "enabled": {
      "default": true,
      "title": "Enabled",
      "type": "boolean"
    },
    "expires_at": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Expires At"
    },
    "expiry_warning_days": {
      "anyOf": [
        {
          "minimum": 1,
          "type": "integer"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Expiry Warning Days"
    },
    "external_ref": {
      "title": "External Ref",
      "type": "string"
    },
    "last_rotated_at": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Last Rotated At"
    },
    "last_validated_at": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Last Validated At"
    },
    "last_validation_message": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Last Validation Message"
    },
    "last_validation_status": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Last Validation Status"
    },
    "max_age_days": {
      "anyOf": [
        {
          "minimum": 1,
          "type": "integer"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Max Age Days"
    },
    "mode": {
      "default": "external_ref",
      "title": "Mode",
      "type": "string"
    },
    "owner": {
      "default": "",
      "title": "Owner",
      "type": "string"
    },
    "provider": {
      "title": "Provider",
      "type": "string"
    },
    "rotation_interval_days": {
      "anyOf": [
        {
          "minimum": 1,
          "type": "integer"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Rotation Interval Days"
    },
    "scopes": {
      "items": {
        "type": "string"
      },
      "title": "Scopes",
      "type": "array"
    },
    "status": {
      "$ref": "#/$defs/CredentialRefStatus",
      "default": "configured"
    },
    "tenant_id": {
      "default": "default",
      "title": "Tenant Id",
      "type": "string"
    },
    "updated_at": {
      "default": "",
      "title": "Updated At",
      "type": "string"
    }
  },
  "required": [
    "credential_ref_id",
    "display_name",
    "provider",
    "external_ref"
  ],
  "title": "CredentialRefRecord",
  "type": "object"
}
