{
  "$defs": {
    "JobStatus": {
      "enum": [
        "pending",
        "running",
        "done",
        "failed",
        "cancelled"
      ],
      "title": "JobStatus",
      "type": "string"
    },
    "ScanRequest": {
      "additionalProperties": false,
      "description": "Options accepted by POST /v1/scan \u2014 mirrors agent-bom scan CLI flags.",
      "properties": {
        "agent_projects": {
          "items": {
            "maxLength": 4096,
            "type": "string"
          },
          "title": "Agent Projects",
          "type": "array"
        },
        "ai_deterministic": {
          "default": false,
          "title": "Ai Deterministic",
          "type": "boolean"
        },
        "ai_enrich": {
          "default": false,
          "title": "Ai Enrich",
          "type": "boolean"
        },
        "ai_model": {
          "default": "openai/gpt-4o-mini",
          "maxLength": 256,
          "title": "Ai Model",
          "type": "string"
        },
        "auto_update_db": {
          "default": false,
          "title": "Auto Update Db",
          "type": "boolean"
        },
        "connectors": {
          "items": {
            "maxLength": 128,
            "type": "string"
          },
          "title": "Connectors",
          "type": "array"
        },
        "db_sources": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Db Sources"
        },
        "dry_run": {
          "default": false,
          "title": "Dry Run",
          "type": "boolean"
        },
        "dynamic_discovery": {
          "default": false,
          "title": "Dynamic Discovery",
          "type": "boolean"
        },
        "dynamic_max_depth": {
          "default": 4,
          "title": "Dynamic Max Depth",
          "type": "integer"
        },
        "enrich": {
          "default": false,
          "title": "Enrich",
          "type": "boolean"
        },
        "exclude_agents": {
          "items": {
            "maxLength": 256,
            "type": "string"
          },
          "title": "Exclude Agents",
          "type": "array"
        },
        "exclude_servers": {
          "items": {
            "maxLength": 256,
            "type": "string"
          },
          "title": "Exclude Servers",
          "type": "array"
        },
        "external_scan": {
          "anyOf": [
            {
              "maxLength": 4096,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "External Scan"
        },
        "filesystem_paths": {
          "items": {
            "maxLength": 4096,
            "type": "string"
          },
          "title": "Filesystem Paths",
          "type": "array"
        },
        "format": {
          "default": "json",
          "enum": [
            "json",
            "cyclonedx",
            "sarif",
            "spdx",
            "html",
            "text"
          ],
          "title": "Format",
          "type": "string"
        },
        "gha_path": {
          "anyOf": [
            {
              "maxLength": 4096,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Gha Path"
        },
        "images": {
          "items": {
            "maxLength": 512,
            "type": "string"
          },
          "title": "Images",
          "type": "array"
        },
        "inventory": {
          "anyOf": [
            {
              "maxLength": 4096,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Inventory"
        },
        "jupyter_dirs": {
          "items": {
            "maxLength": 4096,
            "type": "string"
          },
          "title": "Jupyter Dirs",
          "type": "array"
        },
        "k8s": {
          "default": false,
          "title": "K8S",
          "type": "boolean"
        },
        "k8s_namespace": {
          "anyOf": [
            {
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "K8S Namespace"
        },
        "min_severity": {
          "anyOf": [
            {
              "enum": [
                "low",
                "medium",
                "high",
                "critical"
              ],
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Min Severity"
        },
        "no_scan": {
          "default": false,
          "title": "No Scan",
          "type": "boolean"
        },
        "offline": {
          "default": false,
          "title": "Offline",
          "type": "boolean"
        },
        "repo_url": {
          "anyOf": [
            {
              "maxLength": 2048,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Repo Url"
        },
        "sbom": {
          "anyOf": [
            {
              "maxLength": 4096,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Sbom"
        },
        "scope_agents": {
          "items": {
            "maxLength": 256,
            "type": "string"
          },
          "title": "Scope Agents",
          "type": "array"
        },
        "scope_servers": {
          "items": {
            "maxLength": 256,
            "type": "string"
          },
          "title": "Scope Servers",
          "type": "array"
        },
        "tf_dirs": {
          "items": {
            "maxLength": 4096,
            "type": "string"
          },
          "title": "Tf Dirs",
          "type": "array"
        },
        "vex": {
          "anyOf": [
            {
              "maxLength": 4096,
              "type": "string"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "title": "Vex"
        }
      },
      "title": "ScanRequest",
      "type": "object"
    }
  },
  "description": "Represents a running or completed scan job.",
  "properties": {
    "batch_id": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Batch Id"
    },
    "child_job_ids": {
      "items": {
        "type": "string"
      },
      "title": "Child Job Ids",
      "type": "array"
    },
    "completed_at": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Completed At"
    },
    "created_at": {
      "title": "Created At",
      "type": "string"
    },
    "error": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Error"
    },
    "job_id": {
      "title": "Job Id",
      "type": "string"
    },
    "parent_job_id": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Parent Job Id"
    },
    "progress": {
      "items": {
        "type": "string"
      },
      "title": "Progress",
      "type": "array"
    },
    "request": {
      "$ref": "#/$defs/ScanRequest"
    },
    "result": {
      "anyOf": [
        {
          "additionalProperties": true,
          "type": "object"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Result"
    },
    "schedule_id": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Schedule Id"
    },
    "source_id": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Source Id"
    },
    "started_at": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Started At"
    },
    "status": {
      "$ref": "#/$defs/JobStatus",
      "default": "pending"
    },
    "target": {
      "anyOf": [
        {
          "additionalProperties": true,
          "type": "object"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Target"
    },
    "target_count": {
      "anyOf": [
        {
          "type": "integer"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Target Count"
    },
    "target_index": {
      "anyOf": [
        {
          "type": "integer"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Target Index"
    },
    "tenant_id": {
      "default": "default",
      "title": "Tenant Id",
      "type": "string"
    },
    "triggered_by": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Triggered By"
    }
  },
  "required": [
    "job_id",
    "created_at",
    "request"
  ],
  "title": "ScanJob",
  "type": "object"
}
