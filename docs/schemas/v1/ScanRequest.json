{
  "additionalProperties": false,
  "description": "Options accepted by POST /v1/scan \u2014 mirrors agent-bom scan CLI flags.",
  "properties": {
    "agent_projects": {
      "items": {
        "maxLength": 4096,
        "type": "string"
      },
      "title": "Agent Projects",
      "type": "array"
    },
    "ai_deterministic": {
      "anyOf": [
        {
          "type": "boolean"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Ai Deterministic"
    },
    "ai_enrich": {
      "default": false,
      "title": "Ai Enrich",
      "type": "boolean"
    },
    "ai_model": {
      "default": "openai/gpt-4o-mini",
      "maxLength": 256,
      "title": "Ai Model",
      "type": "string"
    },
    "auto_update_db": {
      "default": false,
      "title": "Auto Update Db",
      "type": "boolean"
    },
    "connectors": {
      "items": {
        "maxLength": 128,
        "type": "string"
      },
      "title": "Connectors",
      "type": "array"
    },
    "db_sources": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Db Sources"
    },
    "dry_run": {
      "default": false,
      "title": "Dry Run",
      "type": "boolean"
    },
    "dynamic_discovery": {
      "default": false,
      "title": "Dynamic Discovery",
      "type": "boolean"
    },
    "dynamic_max_depth": {
      "default": 4,
      "title": "Dynamic Max Depth",
      "type": "integer"
    },
    "enrich": {
      "default": false,
      "title": "Enrich",
      "type": "boolean"
    },
    "exclude_agents": {
      "items": {
        "maxLength": 256,
        "type": "string"
      },
      "title": "Exclude Agents",
      "type": "array"
    },
    "exclude_servers": {
      "items": {
        "maxLength": 256,
        "type": "string"
      },
      "title": "Exclude Servers",
      "type": "array"
    },
    "external_scan": {
      "anyOf": [
        {
          "maxLength": 4096,
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "External Scan"
    },
    "filesystem_paths": {
      "items": {
        "maxLength": 4096,
        "type": "string"
      },
      "title": "Filesystem Paths",
      "type": "array"
    },
    "format": {
      "default": "json",
      "enum": [
        "json",
        "cyclonedx",
        "sarif",
        "spdx",
        "html",
        "text"
      ],
      "title": "Format",
      "type": "string"
    },
    "gha_path": {
      "anyOf": [
        {
          "maxLength": 4096,
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Gha Path"
    },
    "images": {
      "items": {
        "maxLength": 512,
        "type": "string"
      },
      "title": "Images",
      "type": "array"
    },
    "inventory": {
      "anyOf": [
        {
          "maxLength": 4096,
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Inventory"
    },
    "jupyter_dirs": {
      "items": {
        "maxLength": 4096,
        "type": "string"
      },
      "title": "Jupyter Dirs",
      "type": "array"
    },
    "k8s": {
      "default": false,
      "title": "K8S",
      "type": "boolean"
    },
    "k8s_namespace": {
      "anyOf": [
        {
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "K8S Namespace"
    },
    "min_severity": {
      "anyOf": [
        {
          "enum": [
            "low",
            "medium",
            "high",
            "critical"
          ],
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Min Severity"
    },
    "no_scan": {
      "default": false,
      "title": "No Scan",
      "type": "boolean"
    },
    "offline": {
      "default": false,
      "title": "Offline",
      "type": "boolean"
    },
    "repo_url": {
      "anyOf": [
        {
          "maxLength": 2048,
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Repo Url"
    },
    "sbom": {
      "anyOf": [
        {
          "maxLength": 4096,
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Sbom"
    },
    "scope_agents": {
      "items": {
        "maxLength": 256,
        "type": "string"
      },
      "title": "Scope Agents",
      "type": "array"
    },
    "scope_servers": {
      "items": {
        "maxLength": 256,
        "type": "string"
      },
      "title": "Scope Servers",
      "type": "array"
    },
    "tf_dirs": {
      "items": {
        "maxLength": 4096,
        "type": "string"
      },
      "title": "Tf Dirs",
      "type": "array"
    },
    "vex": {
      "anyOf": [
        {
          "maxLength": 4096,
          "type": "string"
        },
        {
          "type": "null"
        }
      ],
      "default": null,
      "title": "Vex"
    }
  },
  "title": "ScanRequest",
  "type": "object"
}
