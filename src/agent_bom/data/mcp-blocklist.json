        "verify_requested_permissions",
        "audit_host_for_reverse_shell_activity"
      ],
      "match_type": "pattern",
      "patterns": [
        "(^|[-_./@])(reverse|bind|back)[-_]?shell($|[-_./])",
        "(^|[-_./@])revshell($|[-_./])",
        "(^|[-_./@])backconnect($|[-_./])",
        "(^|[-_./@])backdoor($|[-_./])"
      ],
      "severity": "high",
      "source": "agent-bom-curated",
      "references": []
