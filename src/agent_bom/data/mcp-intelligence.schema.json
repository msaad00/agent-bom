{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://agent-bom.github.io/schemas/mcp-intelligence/v2",
  "title": "agent-bom MCP intelligence feed",
  "type": "object",
  "required": [
    "schema_version",
    "updated",
    "entries"
  ],
  "properties": {
    "schema_version": {
      "const": 2
    },
    "updated": {
      "type": "string",
      "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
    },
    "description": {
      "type": "string"
    },
    "policy_contract": {
      "type": "object"
    },
    "entries": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "title",
          "description",
          "confidence",
          "default_recommendation",
          "source_type",
          "severity",
          "match_type",
          "last_verified",
          "references"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "title": {
            "type": "string"
          },
          "description": {
            "type": "string"
          },
          "ecosystem": {
            "type": "string"
          },
          "package": {
            "type": "string"
          },
          "affected_versions": {
            "type": "string"
          },
          "confidence": {
            "enum": [
              "confirmed_malicious",
              "suspicious",
              "heuristic"
            ]
          },
          "default_recommendation": {
            "enum": [
              "block",
              "warn",
              "review"
            ]
          },
          "source_type": {
            "enum": [
              "security_advisory",
              "vendor_statement",
              "community_report",
              "package_registry",
              "heuristic"
            ]
          },
          "severity": {
            "enum": [
              "critical",
              "high",
              "medium",
              "low"
            ]
          },
          "match_type": {
            "enum": [
              "exact",
              "pattern"
            ]
          },
          "names": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "registry_ids": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "packages": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "patterns": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "first_seen": {
            "type": "string",
            "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
          },
          "last_verified": {
            "type": "string",
            "pattern": "^\\d{4}-\\d{2}-\\d{2}$"
          },
          "source": {
            "type": "string"
          },
          "references": {
            "type": "array",
            "items": {
              "type": "string",
              "format": "uri"
            }
          },
          "remediation_actions": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        },
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
