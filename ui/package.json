{
  "name": "ui",
  "version": "0.94.2",
  "private": true,
  "packageManager": "npm@10.9.7",
  "engines": {
    "node": ">=22 <25"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build --webpack",
