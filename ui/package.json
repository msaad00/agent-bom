    "test": "vitest",
    "test:run": "vitest run",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build"
  },
  "dependencies": {
    "@dagrejs/dagre": "^3.0.0",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/react-virtual": "^3.14.5",
    "@xyflow/react": "^12.11.2",
    "graphology": "^0.26.0",
    "lucide-react": "^1.23.0",
    "next": "^16.2.10",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "recharts": "^3.9.2",
    "sigma": "^3.0.3"
  },
  "overrides": {
